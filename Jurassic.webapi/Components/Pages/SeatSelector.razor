@page "/seat-selector"
@using BlazorApp1.Models
@using Microsoft.AspNetCore.Components
@using System.Globalization
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>Seat Selector</PageTitle>

<div class="container py-4 pb-5">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <div>
            <h1 class="display-6 fw-bold text-primary mb-1">Choose Your Seats</h1>
            @if (HasMovieShowtimeContext)
            {
                <div class="text-muted">Seats load from the cinema API for your selected movie &amp; showtime.</div>
            }
        </div>
        <button class="btn btn-outline-secondary" @onclick="GoBack">Back</button>
    </div>

    @if (!HasMovieShowtimeContext)
    {
        <div class="alert alert-warning shadow-sm py-4" role="alert">
            <h2 class="alert-heading h5 fw-semibold">Select a movie first</h2>
            <p class="mb-3">Open <strong>Now Playing</strong>, pick a film, then tap a showtime. The seat map only appears after both a movie and a showtime are selected.</p>
            <a href="/now-playing" class="btn btn-primary">Go to Now Playing</a>
        </div>
    }
    else if (_loadingManifest)
    {
        <div class="text-center my-5 py-5">
            <div class="spinner-border text-primary mb-3" role="status"><span class="visually-hidden">Loading seats…</span></div>
            <p class="text-muted">Fetching seat availability…</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(_manifestError))
    {
        <div class="alert alert-danger shadow-sm py-4" role="alert">
            <strong>Could not load seats.</strong> @_manifestError
            <div class="mt-3">
                <button type="button" class="btn btn-primary me-2" @onclick="ReloadManifestAsync">Try again</button>
                <a href="/now-playing" class="btn btn-outline-secondary">Now Playing</a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-12 col-lg-8">
                <div class="card shadow-sm border-0">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div class="fw-semibold text-muted small text-uppercase">Screen</div>
                            <div class="badge bg-dark">@(_lastManifest?.ScreenName ?? "Screen")</div>
                        </div>

                        <div class="text-center mb-3">
                            <div class="screen-pill mx-auto mb-2">SCREEN</div>
                            <div class="small text-muted">Tap seats to select/deselect (API shows what is sold or held).</div>
                        </div>

                        <div class="seat-legend d-flex flex-wrap gap-3 justify-content-center mb-3">
                            <div class="d-flex align-items-center gap-2"><span class="seat-dot available"></span><span class="small text-muted">Available</span></div>
                            <div class="d-flex align-items-center gap-2"><span class="seat-dot selected"></span><span class="small text-muted">Selected</span></div>
                            <div class="d-flex align-items-center gap-2"><span class="seat-dot unavailable"></span><span class="small text-muted">Purchased or held</span></div>
                        </div>

                        <div class="seat-grid mx-auto">
                            @foreach (var seat in _seats)
                            {
                                var css = GetSeatCss(seat);
                                <button type="button"
                                        class="@css"
                                        disabled="@seat.IsUnavailable"
                                        @onclick="() => ToggleSeat(seat)">
                                    @seat.Label
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-4">
                <div class="card shadow-sm border-0 sticky-summary">
                    <div class="card-body">
                        <div class="small text-muted text-uppercase fw-semibold mb-2">Your selection</div>

                        <div class="mb-3">
                            <div class="fw-bold">Movie</div>
                            <div class="text-muted small">@MovieDisplay</div>
                        </div>

                        <div class="mb-3">
                            <div class="fw-bold">Showtime</div>
                            <div class="text-muted small">@ShowtimeDisplay</div>
                        </div>

                        <div class="mb-3">
                            <div class="fw-bold">Price</div>
                            <div class="text-muted small">@PriceDisplay</div>
                        </div>

                        <div class="mb-3">
                            <div class="fw-bold">Seats (@SelectedSeats.Count)</div>
                            @if (SelectedSeats.Count == 0)
                            {
                                <div class="text-muted small">No seats selected yet.</div>
                            }
                            else
                            {
                                <div class="d-flex flex-wrap gap-2 mt-2">
                                    @foreach (var s in SelectedSeats.OrderBy(x => x, StringComparer.OrdinalIgnoreCase))
                                    {
                                        <span class="badge bg-primary">@s</span>
                                    }
                                </div>
                            }
                        </div>

                        <div class="d-flex justify-content-between align-items-center border-top pt-3">
                            <div class="fw-bold">Total</div>
                            <div class="fw-bold">@FormatUsd(Total)</div>
                        </div>

                        <button class="btn btn-success w-100 mt-3"
                                disabled="@(SelectedSeats.Count == 0)"
                                @onclick="GoCheckout">
                            Continue to Checkout
                        </button>

                        <div class="small text-muted mt-2">
                            Purchased seats stay grey—they come from the reservation API after others complete checkout.
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .screen-pill {
        width: min(520px, 100%);
        background: linear-gradient(90deg, rgba(13,110,253,.15), rgba(13,110,253,.03));
        border: 1px solid rgba(13,110,253,.25);
        border-radius: 999px;
        padding: .5rem 1rem;
        font-weight: 700;
        letter-spacing: .12em;
        color: #0d6efd;
    }

    .seat-legend .seat-dot {
        width: 14px;
        height: 14px;
        border-radius: 4px;
        display: inline-block;
        border: 1px solid rgba(0,0,0,.15);
    }
    .seat-dot.available { background: #f8f9fa; }
    .seat-dot.selected { background: #0d6efd; border-color: #0d6efd; }
    .seat-dot.unavailable { background: #adb5bd; }

    .seat-grid {
        display: grid;
        grid-template-columns: repeat(8, minmax(0, 1fr));
        gap: .5rem;
        width: min(520px, 100%);
    }

    .seat-btn {
        border-radius: .5rem;
        padding: .55rem .25rem;
        font-weight: 700;
        border: 1px solid rgba(13,110,253,.25);
        background: #f8f9fa;
        color: #0d6efd;
        transition: transform .08s ease, background .15s ease, border-color .15s ease;
    }
    .seat-btn:hover { transform: translateY(-1px); }
    .seat-btn.selected {
        background: #0d6efd;
        border-color: #0d6efd;
        color: white;
    }
    .seat-btn.unavailable {
        background: #adb5bd;
        border-color: #adb5bd;
        color: #495057;
        cursor: not-allowed;
        opacity: .85;
    }

    .sticky-summary {
        position: sticky;
        top: 1rem;
    }
</style>

@code {
    [SupplyParameterFromQuery]
    public Guid? MovieId { get; set; }

    [SupplyParameterFromQuery]
    public Guid? ShowtimeId { get; set; }

    [SupplyParameterFromQuery]
    public string? MovieTitle { get; set; }

    [SupplyParameterFromQuery]
    public string? StartsAt { get; set; }

    [SupplyParameterFromQuery]
    public string? BasePrice { get; set; }

    private static readonly CultureInfo UsCulture = CultureInfo.GetCultureInfo("en-US");

    private int? _lastLoadedPairKey;
    private bool _loadingManifest;
    private string? _manifestError;
    private ShowtimeSeatsApiDto? _lastManifest;

    private sealed record Seat(string Label, bool IsUnavailable);

    private List<Seat> _seats = new();
    private readonly HashSet<string> SelectedSeats = new(StringComparer.OrdinalIgnoreCase);

    private bool HasMovieShowtimeContext => MovieId.HasValue && ShowtimeId.HasValue;

    private decimal UnitPrice => ParseUnitPrice();

    private decimal Total => UnitPrice * SelectedSeats.Count;

    private string MovieDisplay => string.IsNullOrWhiteSpace(MovieTitle)
        ? _lastManifest?.MovieTitle ?? "Not selected"
        : MovieTitle!;

    private string ShowtimeDisplay
    {
        get
        {
            if (_lastManifest is not null)
            {
                return _lastManifest.StartsAt.ToLocalTime().ToString("ddd, M/d • h:mm tt");
            }

            if (string.IsNullOrWhiteSpace(StartsAt))
            {
                return "Not selected";
            }

            return DateTime.TryParse(StartsAt, CultureInfo.InvariantCulture, DateTimeStyles.RoundtripKind, out var dt)
                ? dt.ToLocalTime().ToString("ddd, M/d • h:mm tt")
                : StartsAt!;
        }
    }

    private string PriceDisplay => $"{FormatUsd(UnitPrice)} per seat";

    private static string FormatUsd(decimal amount) => string.Format(UsCulture, "{0:C}", amount);

    private decimal ParseUnitPrice()
    {
        if (_lastManifest is not null)
        {
            return _lastManifest.BasePrice;
        }

        if (string.IsNullOrWhiteSpace(BasePrice))
        {
            return 0m;
        }

        return decimal.TryParse(BasePrice, NumberStyles.Number, CultureInfo.InvariantCulture, out var d) ? d : 0m;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!HasMovieShowtimeContext)
        {
            _seats.Clear();
            _loadingManifest = false;
            _manifestError = null;
            _lastManifest = null;
            SelectedSeats.Clear();
            _lastLoadedPairKey = null;
            return;
        }

        var pairKey = HashCode.Combine(MovieId!.Value, ShowtimeId!.Value);
        if (pairKey != _lastLoadedPairKey)
        {
            SelectedSeats.Clear();
            _lastLoadedPairKey = pairKey;
        }

        await LoadSeatManifestAsync();
    }

    private async Task ReloadManifestAsync()
    {
        await LoadSeatManifestAsync();
    }

    private async Task LoadSeatManifestAsync()
    {
        _manifestError = null;
        _loadingManifest = true;
        try
        {
            var url = $"movies/{MovieId!.Value}/showtimes/{ShowtimeId!.Value}/seats";
            var dto = await Http.GetFromJsonAsync<ShowtimeSeatsApiDto>(url);
            if (dto is null || dto.Seats.Count == 0)
            {
                _manifestError = "The seat list was empty.";
                _seats.Clear();
                _lastManifest = null;
                return;
            }

            _lastManifest = dto;
            if (string.IsNullOrWhiteSpace(MovieTitle))
            {
                MovieTitle = dto.MovieTitle;
            }

            if (string.IsNullOrWhiteSpace(StartsAt))
            {
                StartsAt = dto.StartsAt.ToUniversalTime().ToString("o");
            }

            BasePrice ??= dto.BasePrice.ToString(CultureInfo.InvariantCulture);

            _seats = dto.Seats
                .Where(s => !string.IsNullOrWhiteSpace(s.Label))
                .Select(s => new Seat(s.Label.Trim().ToUpperInvariant(), !s.Available))
                .OrderBy(s => s.Label, StringComparer.Ordinal)
                .ToList();

            var unavailable = dto.Seats.Where(s => !s.Available).Select(s => s.Label.Trim().ToUpperInvariant()).ToHashSet(StringComparer.Ordinal);
            SelectedSeats.RemoveWhere(sl => unavailable.Contains(sl.Trim().ToUpperInvariant()));
        }
        catch (Exception ex)
        {
            _manifestError = string.IsNullOrWhiteSpace(ex.Message) ? "API error." : ex.Message;
            _seats.Clear();
            _lastManifest = null;
        }
        finally
        {
            _loadingManifest = false;
        }
    }

    private string GetSeatCss(Seat seat)
    {
        var selected = SelectedSeats.Contains(seat.Label);
        return seat.IsUnavailable ? "seat-btn unavailable" : selected ? "seat-btn selected" : "seat-btn";
    }

    private void ToggleSeat(Seat seat)
    {
        if (seat.IsUnavailable)
        {
            return;
        }

        if (!SelectedSeats.Add(seat.Label))
        {
            SelectedSeats.Remove(seat.Label);
        }
    }

    private void GoCheckout()
    {
        var query = new List<string>
        {
            $"movieId={MovieId!.Value}",
            $"showtimeId={ShowtimeId!.Value}",
        };

        if (!string.IsNullOrWhiteSpace(MovieTitle))
        {
            query.Add($"movieTitle={Uri.EscapeDataString(MovieTitle!)}");
        }

        if (!string.IsNullOrWhiteSpace(StartsAt))
        {
            query.Add($"startsAt={Uri.EscapeDataString(StartsAt!)}");
        }

        query.Add($"basePrice={Uri.EscapeDataString(UnitPrice.ToString(CultureInfo.InvariantCulture))}");
        query.Add($"seats={Uri.EscapeDataString(string.Join(",", SelectedSeats.OrderBy(x => x, StringComparer.OrdinalIgnoreCase)))}");
        query.Add($"total={Uri.EscapeDataString(Total.ToString(CultureInfo.InvariantCulture))}");

        Nav.NavigateTo("/checkout?" + string.Join("&", query));
    }

    private void GoBack() => Nav.NavigateTo("/now-playing");
}
