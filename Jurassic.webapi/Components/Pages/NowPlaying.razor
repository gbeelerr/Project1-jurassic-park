@page "/now-playing"
@using BlazorApp1.Models
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>Now Playing</PageTitle>

<h1>Now Playing</h1>

<p>Select a movie to continue.</p>

@if (_isError)
{
    <p>Movies currently not available. Please try again later.</p>
}
else if (movies == null)
{
    <p>Loading movies...</p>
}
else if (movies.Count == 0)
{
    <p>No movies found.</p>
}
else
{
    <ul>
        @foreach (var movie in movies)
        {
            <li class="mb-2">
                <strong>@movie.Title</strong> - @movie.Runtime mins
                <button class="btn btn-success ms-2" @onclick="GoToSeatSelector">
                    Book
                </button>
            </li>
        }
    </ul>
}

<button class="btn btn-secondary" @onclick="GoHome">Back</button>

@code {
    private List<Movie>? movies;
    private bool _isError;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            movies = await Http.GetFromJsonAsync<List<Movie>>("movies");
        }
        catch (Exception ex)
        {
            _isError = true;
            // Optionally log the error here if logging was set up
        }
    }

    private void GoToSeatSelector()
    {
        Nav.NavigateTo("/seat-selector");
    }

    private void GoHome()
    {
        Nav.NavigateTo("/");
    }
}