@page "/seat-selector"
@using Microsoft.AspNetCore.Components
@inject NavigationManager Nav

<PageTitle>Seat Selector</PageTitle>

<h1>Select Your Seats</h1>

<p>(Seat map will be implemented later)</p>

@if (MovieId.HasValue || ShowtimeId.HasValue)
{
    <div class="alert alert-info" role="alert">
        <div><strong>Selected movie:</strong> @MovieId</div>
        <div><strong>Selected showtime:</strong> @ShowtimeId</div>
    </div>
}

<div class="mb-3">
    <button class="btn btn-outline-primary me-2">A1</button>
    <button class="btn btn-outline-primary me-2">A2</button>
    <button class="btn btn-outline-primary me-2">B1</button>
    <button class="btn btn-outline-primary me-2">B2</button>
</div>

<button class="btn btn-success me-2" @onclick="GoCheckout">
    Continue to Checkout
</button>

<button class="btn btn-secondary" @onclick="GoBack">
    Back
</button>

@code {
    [SupplyParameterFromQuery]
    public Guid? MovieId { get; set; }

    [SupplyParameterFromQuery]
    public Guid? ShowtimeId { get; set; }

    private void GoCheckout()
    {
        Nav.NavigateTo("/checkout");
    }

    private void GoBack()
    {
        Nav.NavigateTo("/now-playing");
    }
}
