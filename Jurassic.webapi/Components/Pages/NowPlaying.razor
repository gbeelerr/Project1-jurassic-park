@page "/now-playing"
@using BlazorApp1.Models
@using BlazorApp1.Services
@using System.Net.Http.Json
@using System.Globalization
@inject HttpClient Http
@inject NavigationManager Nav
@inject InfinityRatingsClient RatingsClient
@inject UserSession Session

<PageTitle>Now Playing</PageTitle>

<div class="container mt-4 pb-5">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <h1 class="display-5 fw-bold text-primary">Now Playing</h1>
        <button class="btn btn-outline-secondary" @onclick="GoHome">
            Back Home
        </button>
    </div>

    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-4">
        <p class="lead text-muted mb-0">Select a date, then pick a movie/showtime to start booking.</p>
        <div class="d-flex align-items-center gap-2">
            <label class="small text-muted fw-semibold mb-0" for="nowPlayingDate">Show date</label>
            <input id="nowPlayingDate"
                   type="date"
                   class="form-control"
                   style="max-width: 180px;"
                   value="@_selectedDateIso"
                   @onchange="OnDateChanged" />
        </div>
    </div>

    @if (_isError)
    {
        <div class="alert alert-danger shadow-sm py-4" role="alert">
            <h4 class="alert-heading fw-bold">Connection Error</h4>
            <p class="mb-0">Movies currently not available. Our systems might be experiencing some issues. Please try again later.</p>
        </div>
    }
    else if (movies == null)
    {
        <div class="text-center my-5 py-5">
            <div class="spinner-border text-primary mb-3" style="width: 3rem; height: 3rem;" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="text-muted">Fetching the latest blockbusters...</p>
        </div>
    }
    else if (movies.Count == 0)
    {
        <div class="alert alert-info shadow-sm py-4 text-center" role="alert">
            <h4 class="alert-heading fw-bold">No Movies Currently Showing</h4>
            <p class="mb-0">Please check back later for the next scheduled features.</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var movie in movies)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm transition-hover">
                        <div class="poster-wrap">
                            @if (!string.IsNullOrEmpty(movie.PosterUrl))
                            {
                                <img src="@movie.PosterUrl" class="card-img-top" alt="@movie.Title Poster" style="object-fit: cover; height: 350px;">
                            }
                            else
                            {
                                <div class="card-img-top bg-dark d-flex flex-column align-items-center justify-content-center text-white p-4" style="height: 350px;">
                                    <div class="mb-2 text-secondary h4">Now Showing</div>
                                    <h5 class="fw-bold text-center">@movie.Title</h5>
                                    <span class="badge bg-secondary mt-2">Poster Coming Soon</span>
                                </div>
                            }
                            @if (_ratingsByMovie.TryGetValue(movie.MovieId, out var rating))
                            {
                                <div class="rating-overlay" title="Average rating">
                                    @BuildStars(rating.AvgStars)
                                    <span class="rating-meta">@rating.AvgStars.ToString("0.0") (@rating.ReviewCount)</span>
                                </div>
                            }
                        </div>

                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <h5 class="card-title fw-bold mb-0">@movie.Title</h5>
                                <span class="badge bg-info text-dark">@movie.Rating</span>
                            </div>

                            <div class="d-flex flex-wrap gap-2 mb-3 text-muted small">
                                <span class="d-inline-flex align-items-center">
                                    Runtime: @movie.DurationMins mins
                                </span>
                                <span class="d-inline-flex align-items-center">
                                    Screen: @movie.ScreenName (@movie.ScreenType)
                                </span>
                            </div>

                            <button class="btn btn-outline-info btn-sm w-100" @onclick="() => ShowDescription(movie)">
                                Movie Info
                            </button>
                        </div>

                        <div class="card-footer bg-white border-top-0 pt-0 pb-3 px-3">
                            <div class="small text-uppercase fw-bold text-muted mb-2">Showtimes</div>
                            @if (movie.Showtimes != null && movie.Showtimes.Any())
                            {
                                @foreach (var showtimeGroup in GetShowtimeGroups(movie.Showtimes))
                                {
                                    <div class="showtime-day mb-3">
                                        <div class="small fw-semibold text-dark mb-2">@FormatShowDate(showtimeGroup.Key)</div>
                                        <div class="showtime-grid">
                                            @foreach (var showtime in showtimeGroup)
                                            {
                                                <button class="btn btn-success shadow-sm fw-bold showtime-button" @onclick="() => GoToSeatSelector(movie.MovieId, movie.Title, showtime.ShowtimeId, showtime.StartsAt, showtime.BasePrice)">
                                                    <span>@FormatShowTime(showtime.StartsAt)</span>
                                                    <span class="small">@FormatUsd(showtime.BasePrice)</span>
                                                </button>
                                            }
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="text-muted small">No showtimes available for this screen.</div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (_selectedMovie != null)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.6); backdrop-filter: blur(4px);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-lg border-0">
                <div class="modal-header bg-primary text-white border-0">
                    <h5 class="modal-title fw-bold">@_selectedMovie.Title</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseDescription"></button>
                </div>
                <div class="modal-body p-4">
                    @if (!string.IsNullOrWhiteSpace(_selectedMovie.PosterUrl))
                    {
                        <img src="@_selectedMovie.PosterUrl"
                             class="w-100 rounded mb-3"
                             alt="@_selectedMovie.Title Poster"
                             style="max-height: 320px; object-fit: cover;" />
                    }
                    <div class="d-flex mb-3 gap-2">
                        <span class="badge bg-secondary">Rating: @_selectedMovie.Rating</span>
                        <span class="badge bg-secondary">Duration: @_selectedMovie.DurationMins mins</span>
                    </div>
                    <h6 class="fw-bold text-uppercase small text-muted mb-2">Synopsis</h6>
                    <p class="text-secondary mb-4" style="line-height: 1.6;">
                        @(!string.IsNullOrWhiteSpace(_selectedMovie.Description)
                            ? _selectedMovie.Description
                            : "Synopsis coming soon.")
                    </p>

                    <h6 class="fw-bold text-uppercase small text-muted mb-2">Screening Details</h6>
                    <p class="mb-3 text-dark">
                        Screen: <strong>@_selectedMovie.ScreenName</strong> (@_selectedMovie.ScreenType)
                    </p>

                    <h6 class="fw-bold text-uppercase small text-muted mb-2">Available Showtimes</h6>
                    <div class="mb-4">
                        @if (_selectedMovie.Showtimes != null && _selectedMovie.Showtimes.Any())
                        {
                            @foreach (var showtimeGroup in GetShowtimeGroups(_selectedMovie.Showtimes))
                            {
                                <div class="showtime-day mb-3">
                                    <div class="small fw-semibold text-dark mb-2">@FormatShowDate(showtimeGroup.Key)</div>
                                    <div class="showtime-grid">
                                        @foreach (var showtime in showtimeGroup)
                                        {
                                            <button type="button" class="btn btn-outline-success showtime-button" @onclick="() => BookSelectedShowtime(_selectedMovie.MovieId, _selectedMovie.Title, showtime.ShowtimeId, showtime.StartsAt, showtime.BasePrice)">
                                                <span>@FormatShowTime(showtime.StartsAt)</span>
                                                <span class="small">@FormatUsd(showtime.BasePrice)</span>
                                            </button>
                                        }
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <span class="text-muted small italic">No showtimes available for this screen.</span>
                        }
                    </div>

                    <h6 class="fw-bold text-uppercase small text-muted mb-2">Movie Ratings & Reviews</h6>
                    <div class="border rounded p-3 bg-light mb-2">
                        @if (_selectedMovie != null && _ratingsByMovie.TryGetValue(_selectedMovie.MovieId, out var modalRating))
                        {
                            <div class="small text-muted mb-2">
                                Average: <span class="fw-semibold text-dark">@modalRating.AvgStars.ToString("0.0")</span>
                                from <span class="fw-semibold text-dark">@modalRating.ReviewCount</span> reviews
                            </div>
                        }

                        @if (string.IsNullOrWhiteSpace(Session.InfinityAccessToken))
                        {
                            <div class="small text-muted mb-2">Sign in with your Infinity (8082) account to post reviews and ratings.</div>
                            <div class="row g-2 mb-2">
                                <div class="col-12 col-md-5">
                                    <input class="form-control form-control-sm" @bind="_infinityUsername" placeholder="Username" />
                                </div>
                                <div class="col-12 col-md-5">
                                    <input type="password" class="form-control form-control-sm" @bind="_infinityPassword" placeholder="Password" />
                                </div>
                                <div class="col-12 col-md-2 d-grid">
                                    <button type="button" class="btn btn-sm btn-outline-primary" @onclick="InfinitySignInAsync" disabled="@_authBusy">Sign in</button>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="d-flex justify-content-between align-items-center mb-2 small">
                                <span>Signed in as <span class="fw-semibold">@Session.InfinityUsername</span></span>
                                <button type="button" class="btn btn-sm btn-link p-0" @onclick="InfinitySignOut">Sign out</button>
                            </div>

                            <div class="fw-bold small text-uppercase text-muted mb-2">Your Movie Rating</div>
                            <div class="d-flex align-items-center gap-3 mb-3">
                                <div class="star-picker"
                                     role="group"
                                     aria-label="Star rating"
                                     @onmouseleave="OnStarPickerLeave">
                                    @for (var star = 1; star <= 5; star++)
                                    {
                                        var s = star;
                                        <button type="button"
                                                class="star-pick-btn"
                                                @onclick="() => OnStarClick(s)"
                                                @onmouseover="() => OnStarHover(s)">
                                            <span class="star-pick-char @(StarFilled(s) ? "star-full" : "star-empty")">★</span>
                                        </button>
                                    }
                                </div>
                                <button type="button"
                                        class="btn btn-sm btn-primary"
                                        @onclick="SubmitRatingAsync"
                                        disabled="@(_ratingSubmitBusy || _selectedMovie == null || !_draftStars.HasValue)">
                                    Save Rating
                                </button>
                            </div>
                            @if (_userRatingFetched && _draftStars == 0)
                            {
                                <div class="small text-muted mb-3 italic">You haven't rated this movie yet. Tap stars to rate.</div>
                            }

                            <div class="fw-bold small text-uppercase text-muted mb-2">Write a Review</div>
                            <textarea class="form-control form-control-sm mb-2"
                                      rows="3"
                                      @bind="_newReviewContent"
                                      placeholder="Share your thoughts about this movie..."></textarea>
                            <div class="d-flex gap-2 mb-2">
                                <button type="button"
                                        class="btn btn-sm btn-primary"
                                        @onclick="SubmitReviewAsync"
                                        disabled="@(_reviewSubmitBusy || _selectedMovie == null || string.IsNullOrWhiteSpace(_newReviewContent))">
                                    @(_editingReviewId.HasValue ? "Update Review" : "Post Review")
                                </button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ResetReviewDraft">Clear</button>
                            </div>
                        }

                        @if (!string.IsNullOrWhiteSpace(_reviewError))
                        {
                            <div class="alert alert-warning py-2 small mt-2 mb-0">@_reviewError</div>
                        }
                    </div>

                    <div class="small text-muted mb-2">Recent reviews</div>
                    @if (_reviewsLoading)
                    {
                        <div class="text-muted small">Loading reviews...</div>
                    }
                    else if (_selectedMovieReviews.Count == 0)
                    {
                        <div class="text-muted small">No reviews yet for this movie.</div>
                    }
                    else
                    {
                        @foreach (var review in _selectedMovieReviews)
                        {
                            <div class="border rounded p-2 mb-2 bg-white">
                                <div class="d-flex justify-content-between align-items-start gap-2">
                                    <div>
                                        <div class="fw-semibold small">@review.Author</div>
                                    </div>
                                    <div class="text-muted small">@review.Date</div>
                                </div>
                                <div class="small mt-1">@review.Content</div>
                                @if (review.IsOwner && !string.IsNullOrWhiteSpace(Session.InfinityAccessToken))
                                {
                                    <div class="d-flex gap-2 mt-2">
                                        <button class="btn btn-sm btn-outline-primary" @onclick="() => StartEditReview(review)">Edit</button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteReviewAsync(review.Id)">Delete</button>
                                    </div>
                                }
                            </div>
                        }
                    }
                </div>
                <div class="modal-footer border-top-0 p-3">
                    <button type="button" class="btn btn-secondary px-4" @onclick="CloseDescription">Close</button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .transition-hover {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .transition-hover:hover {
        transform: translateY(-8px);
        box-shadow: 0 1rem 3rem rgba(0,0,0,.175)!important;
    }

    .showtime-grid {
        display: grid;
        gap: 0.75rem;
        grid-template-columns: repeat(auto-fit, minmax(110px, 1fr));
    }

    .showtime-button {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 68px;
    }

    .poster-wrap {
        position: relative;
    }

    .rating-overlay {
        position: absolute;
        top: 0.5rem;
        right: 0.5rem;
        background: rgba(0, 0, 0, 0.78);
        color: #facc2e;
        border-radius: 0.35rem;
        padding: 0.25rem 0.45rem;
        font-size: 0.8rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 0.35rem;
        box-shadow: 0 0.3rem 0.9rem rgba(0, 0, 0, 0.45);
    }

    .rating-meta {
        color: #ffffff;
        font-weight: 600;
        font-size: 0.72rem;
    }

    .star-picker {
        user-select: none;
    }

    .star-pick-btn {
        border: 0;
        background: transparent;
        padding: 0 0.12rem;
        line-height: 1;
        cursor: pointer;
    }

    .star-pick-char {
        font-size: 1.45rem;
        line-height: 1;
        display: inline-block;
    }

    .star-empty {
        color: #9ca3af;
    }

    .star-full {
        color: #facc15;
        text-shadow: 0 0 1px rgba(0, 0, 0, 0.35);
    }
</style>

@code {
    private List<Movie>? movies;
    private bool _isError;
    private Movie? _selectedMovie;
    private string _selectedDateIso = DateTime.UtcNow.ToString("yyyy-MM-dd");
    private static readonly CultureInfo UsCulture = CultureInfo.GetCultureInfo("en-US");
    private Dictionary<Guid, MovieRatingSummaryItem> _ratingsByMovie = new();
    private List<InfinityReviewItem> _selectedMovieReviews = [];
    private bool _reviewsLoading;
    private bool _reviewSubmitBusy;
    private bool _ratingSubmitBusy;
    private bool _authBusy;
    private bool _userRatingFetched;
    private string? _reviewError;
    private int? _draftStars;
    private int _hoverStars;
    private string _newReviewContent = "";
    private Guid? _editingReviewId;
    private string _infinityUsername = "";
    private string _infinityPassword = "";

    protected override async Task OnInitializedAsync()
    {
        await FetchMoviesAsync();
    }

    private async Task OnDateChanged(ChangeEventArgs e)
    {
        _selectedDateIso = e.Value?.ToString() ?? DateTime.UtcNow.ToString("yyyy-MM-dd");
        await FetchMoviesAsync();
    }

    private async Task FetchMoviesAsync()
    {
        _isError = false;
        movies = null;

        try
        {
            var url = $"movies/now-playing?date={Uri.EscapeDataString(_selectedDateIso)}";
            var moviesTask = Http.GetFromJsonAsync<List<Movie>>(url);
            var ratingsTask = RatingsClient.GetRatingsSummaryAsync();
            await Task.WhenAll(moviesTask, ratingsTask);
            movies = await moviesTask ?? [];
            var ratings = await ratingsTask;
            _ratingsByMovie = ratings.ToDictionary(item => item.MovieId, item => item);
        }
        catch (Exception ex)
        {
            _isError = true;
            Console.WriteLine($"Error fetching movies: {ex.Message}");
        }
    }

    private async Task ShowDescription(Movie movie)
    {
        _selectedMovie = movie;
        _hoverStars = 0;
        _userRatingFetched = false;
        ResetReviewDraft();
        await Task.WhenAll(LoadSelectedMovieReviewsAsync(), LoadUserRatingAsync());
    }

    private void CloseDescription()
    {
        _selectedMovie = null;
        _selectedMovieReviews = [];
        _reviewError = null;
        _editingReviewId = null;
    }

    private static IEnumerable<IGrouping<DateOnly, ShowtimeDetail>> GetShowtimeGroups(IEnumerable<ShowtimeDetail> showtimes)
    {
        return showtimes
            .OrderBy(showtime => showtime.StartsAt)
            .GroupBy(showtime => DateOnly.FromDateTime(showtime.StartsAt));
    }

    private static string FormatShowDate(DateOnly date)
    {
        return date.ToString("ddd, M/d");
    }

    private static string FormatShowTime(DateTime startsAt)
    {
        return startsAt.ToString("h:mm tt");
    }

    private static string FormatUsd(decimal amount) => string.Format(UsCulture, "{0:C}", amount);

    private void BookSelectedShowtime(Guid movieId, string movieTitle, Guid showtimeId, DateTime startsAt, decimal basePrice)
    {
        CloseDescription();
        GoToSeatSelector(movieId, movieTitle, showtimeId, startsAt, basePrice);
    }

    private void GoToSeatSelector(Guid movieId, string? movieTitle = null, Guid? showtimeId = null, DateTime? startsAt = null, decimal? basePrice = null)
    {
        var query = new List<string> { $"movieId={movieId}" };

        if (!string.IsNullOrWhiteSpace(movieTitle))
        {
            query.Add($"movieTitle={Uri.EscapeDataString(movieTitle)}");
        }

        if (showtimeId.HasValue)
        {
            query.Add($"showtimeId={showtimeId.Value}");
        }

        if (startsAt.HasValue)
        {
            query.Add($"startsAt={Uri.EscapeDataString(startsAt.Value.ToUniversalTime().ToString("o"))}");
        }

        if (basePrice.HasValue)
        {
            query.Add($"basePrice={Uri.EscapeDataString(basePrice.Value.ToString(CultureInfo.InvariantCulture))}");
        }

        var url = "/seat-selector" + (query.Count > 0 ? "?" + string.Join("&", query) : "");

        Nav.NavigateTo(url);
    }

    private void GoHome()
    {
        Nav.NavigateTo("/");
    }

    private static string BuildStars(decimal avg)
    {
        var rounded = (int)Math.Round(avg, MidpointRounding.AwayFromZero);
        rounded = Math.Clamp(rounded, 0, 5);
        return new string('★', rounded).PadRight(5, '☆');
    }

    private static string FormatReviewStars(InfinityReviewItem review) =>
        review.Stars > 0 ? BuildStars(review.Stars) : BuildStars(0);

    private string StarPickerHint =>
        _draftStars.HasValue ? "" : "Tap a star (1–5). Grey = not selected, gold = your rating.";

    private bool StarFilled(int star)
    {
        var upTo = _hoverStars > 0 ? _hoverStars : (_draftStars ?? 0);
        return star <= upTo;
    }

    private void OnStarHover(int star)
    {
        _hoverStars = star;
        StateHasChanged();
    }

    private void OnStarPickerLeave()
    {
        _hoverStars = 0;
        StateHasChanged();
    }

    private void OnStarClick(int star)
    {
        _draftStars = star;
        _hoverStars = 0;
        _reviewError = null;
        StateHasChanged();
    }

    private async Task LoadUserRatingAsync()
    {
        if (_selectedMovie == null || string.IsNullOrWhiteSpace(Session.InfinityAccessToken))
        {
            return;
        }

        try
        {
            var rating = await RatingsClient.GetUserRatingAsync(_selectedMovie.MovieId);
            _draftStars = rating.Stars;
            _userRatingFetched = true;
        }
        catch
        {
            _draftStars = 0;
        }
    }

    private async Task SubmitRatingAsync()
    {
        if (_selectedMovie == null || !_draftStars.HasValue || _draftStars.Value == 0)
        {
            return;
        }

        _ratingSubmitBusy = true;
        _reviewError = null;
        try
        {
            var ok = await RatingsClient.UpsertRatingAsync(_selectedMovie.MovieId, _draftStars.Value);
            if (!ok)
            {
                _reviewError = "Could not update rating. Verify Infinity sign in.";
            }
            else
            {
                // Refresh summary to show updated average
                var ratings = await RatingsClient.GetRatingsSummaryAsync();
                _ratingsByMovie = ratings.ToDictionary(item => item.MovieId, item => item);
            }
        }
        catch
        {
            _reviewError = "Something went wrong while saving your rating.";
        }
        finally
        {
            _ratingSubmitBusy = false;
        }
    }

    private async Task LoadSelectedMovieReviewsAsync()
    {
        if (_selectedMovie is null)
        {
            return;
        }

        _reviewsLoading = true;
        _reviewError = null;
        try
        {
            _selectedMovieReviews = await RatingsClient.GetReviewsAsync(_selectedMovie.MovieId);
        }
        catch
        {
            _selectedMovieReviews = [];
            _reviewError = "Could not load reviews for this movie.";
        }
        finally
        {
            _reviewsLoading = false;
        }
    }

    private async Task SubmitReviewAsync()
    {
        if (_selectedMovie is null)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(_newReviewContent))
        {
            _reviewError = "Please enter some review text.";
            return;
        }

        _reviewSubmitBusy = true;
        _reviewError = null;
        try
        {
            var text = _newReviewContent ?? "";
            var ok = _editingReviewId.HasValue
                ? await RatingsClient.UpdateReviewAsync(_selectedMovie.MovieId, _editingReviewId.Value, text)
                : await RatingsClient.CreateReviewAsync(_selectedMovie.MovieId, text);

            if (!ok)
            {
                _reviewError = "Review request was rejected. Verify Infinity sign in.";
                return;
            }

            ResetReviewDraft();
            await LoadSelectedMovieReviewsAsync();
        }
        catch (Exception)
        {
            _reviewError = "Something went wrong while saving your review. Please try again.";
        }
        finally
        {
            _reviewSubmitBusy = false;
        }
    }

    private void StartEditReview(InfinityReviewItem review)
    {
        _editingReviewId = review.Id;
        _newReviewContent = review.Content;
    }

    private async Task DeleteReviewAsync(Guid reviewId)
    {
        if (_selectedMovie is null)
        {
            return;
        }

        _reviewSubmitBusy = true;
        try
        {
            var ok = await RatingsClient.DeleteReviewAsync(_selectedMovie.MovieId, reviewId);
            if (!ok)
            {
                _reviewError = "Could not delete that review.";
                return;
            }

            await LoadSelectedMovieReviewsAsync();
        }
        catch (Exception)
        {
            _reviewError = "Something went wrong while deleting the review.";
        }
        finally
        {
            _reviewSubmitBusy = false;
        }
    }

    private void ResetReviewDraft()
    {
        _editingReviewId = null;
        _draftStars = null;
        _hoverStars = 0;
        _newReviewContent = "";
    }


    private async Task InfinitySignInAsync()
    {
        _reviewError = null;
        _authBusy = true;
        try
        {
            var auth = await RatingsClient.LoginAsync(_infinityUsername, _infinityPassword);
            if (auth is null || string.IsNullOrWhiteSpace(auth.Token))
            {
                _reviewError = "Infinity sign in failed.";
                return;
            }

            Session.InfinityAccessToken = auth.Token;
            Session.InfinityUsername = auth.Username;
            Session.NotifyChanged();
            await Task.WhenAll(LoadSelectedMovieReviewsAsync(), LoadUserRatingAsync());
        }
        finally
        {
            _authBusy = false;
        }
    }

    private void InfinitySignOut()
    {
        Session.InfinityAccessToken = null;
        Session.InfinityUsername = null;
        Session.NotifyChanged();
    }
}
