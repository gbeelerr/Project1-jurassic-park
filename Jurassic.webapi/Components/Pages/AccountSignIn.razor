@page "/account"
@using System.Net
@using System.Net.Http.Json
@using BlazorApp1.Models
@using BlazorApp1.Services
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@rendermode InteractiveServer
@inject HttpClient Http
@inject NavigationManager Nav
@inject UserSession Session

<PageTitle>Sign in</PageTitle>

<div class="container py-5 account-page" style="max-width: 560px;">
    <div class="text-center account-header mb-4">
        <div class="eyebrow mb-2">Your cinema account</div>
        <h1 class="h2 fw-bold mb-2">Sign in or create an account</h1>
        <p class="text-muted mb-0">Book faster and keep your purchased seats in one place.</p>
    </div>

    <ul class="nav nav-pills nav-fill mb-4" role="tablist">
        <li class="nav-item" role="presentation">
            <button type="button" class="nav-link @(_tab == Tab.SignIn ? "active" : null)" @onclick="() => _tab = Tab.SignIn">Sign in</button>
        </li>
        <li class="nav-item" role="presentation">
            <button type="button" class="nav-link @(_tab == Tab.SignUp ? "active" : null)" @onclick="() => _tab = Tab.SignUp">Create account</button>
        </li>
    </ul>

    @if (_tab == Tab.SignIn)
    {
        <div class="card account-card shadow-sm border-0">
            <div class="card-body p-4">
                <p class="text-muted small mb-3">Use the email and password for your account. Demo user is seeded when the database is empty (see README).</p>
                @if (!string.IsNullOrEmpty(_signInError))
                {
                    <div class="alert alert-danger py-2 small" role="alert">@_signInError</div>
                }
                <div class="mb-3">
                    <label class="form-label" for="signInEmail">Email</label>
                    <input id="signInEmail" type="email" class="form-control" @bind="_signInEmail" autocomplete="username" />
                </div>
                <div class="mb-3">
                    <label class="form-label" for="signInPassword">Password</label>
                    <input id="signInPassword" type="password" class="form-control" @bind="_signInPassword" autocomplete="current-password" />
                </div>
                <button type="button" class="btn btn-primary w-100" disabled="@_busy" @onclick="SignInAsync">
                    @(_busy ? "Signing in…" : "Sign in")
                </button>
            </div>
        </div>
    }
    else
    {
        <div class="card account-card shadow-sm border-0">
            <div class="card-body p-4">
                <p class="text-muted small mb-3">Password must be at least 8 characters.</p>
                @if (!string.IsNullOrEmpty(_signUpError))
                {
                    <div class="alert alert-danger py-2 small" role="alert">@_signUpError</div>
                }
                @if (!string.IsNullOrEmpty(_signUpSuccess))
                {
                    <div class="alert alert-success py-2 small" role="alert">@_signUpSuccess</div>
                }
                <div class="mb-3">
                    <label class="form-label" for="signUpEmail">Email</label>
                    <input id="signUpEmail" type="email" class="form-control" @bind="_signUpEmail" autocomplete="username" />
                </div>
                <div class="mb-3">
                    <label class="form-label" for="signUpDisplayName">Display name (optional)</label>
                    <input id="signUpDisplayName" type="text" class="form-control" @bind="_signUpDisplayName" autocomplete="name" />
                </div>
                <div class="mb-3">
                    <label class="form-label" for="signUpPassword">Password</label>
                    <input id="signUpPassword" type="password" class="form-control" @bind="_signUpPassword" autocomplete="new-password" />
                </div>
                <button type="button" class="btn btn-primary w-100" disabled="@_busy" @onclick="SignUpAsync">
                    @(_busy ? "Creating account…" : "Create account")
                </button>
            </div>
        </div>
    }

    <div class="mt-4 text-center">
        <a href="/">Back to home</a>
    </div>
</div>

<style>
    .account-page .account-header {
        color: #fff;
    }

    .account-page .account-header h1 {
        color: #fff;
    }

    .account-page .account-header .text-muted {
        color: rgba(255, 255, 255, 0.72) !important;
    }

    .account-page .nav-pills {
        background: rgba(255, 255, 255, 0.88);
        border: 1px solid rgba(24, 33, 47, 0.1);
        border-radius: 0.7rem;
        padding: 0.35rem;
        box-shadow: 0 12px 30px rgba(24, 33, 47, 0.08);
    }

    .account-page .nav-pills .nav-link {
        border-radius: 0.45rem;
        color: #18212f;
        font-weight: 800;
    }

    .account-page .nav-pills .nav-link.active {
        background: #b42318;
        color: #fff;
    }

    .account-card {
        background: rgba(255, 255, 255, 0.96);
    }

    .account-page a {
        font-weight: 700;
    }
</style>

@code {
    private enum Tab { SignIn, SignUp }

    private Tab _tab = Tab.SignIn;
    private bool _busy;

    private string _signInEmail = "";
    private string _signInPassword = "";
    private string? _signInError;

    private string _signUpEmail = "";
    private string _signUpPassword = "";
    private string _signUpDisplayName = "";
    private string? _signUpError;
    private string? _signUpSuccess;

    private async Task SignInAsync()
    {
        _signInError = null;
        _busy = true;
        try
        {
            var response = await Http.PostAsJsonAsync("auth/login", new { email = _signInEmail, password = _signInPassword });
            if (response.StatusCode == HttpStatusCode.Unauthorized)
            {
                _signInError = "Invalid email or password.";
                return;
            }

            response.EnsureSuccessStatusCode();
            var payload = await response.Content.ReadFromJsonAsync<AuthLoginResponse>();
            if (payload is null || string.IsNullOrEmpty(payload.AccessToken))
            {
                _signInError = "Unexpected response from server.";
                return;
            }

            CompleteSignIn(_signInEmail, payload);
        }
        catch (Exception ex)
        {
            _signInError = $"Could not sign in: {ex.Message}";
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task SignUpAsync()
    {
        _signUpError = null;
        _signUpSuccess = null;
        _busy = true;
        try
        {
            if (string.IsNullOrWhiteSpace(_signUpPassword) || _signUpPassword.Length < 8)
            {
                _signUpError = "Password must be at least 8 characters.";
                return;
            }

            var body = new
            {
                email = _signUpEmail,
                password = _signUpPassword,
                display_name = string.IsNullOrWhiteSpace(_signUpDisplayName) ? null : _signUpDisplayName.Trim()
            };

            var response = await Http.PostAsJsonAsync("auth/register", body);
            if (response.StatusCode == HttpStatusCode.Conflict)
            {
                _signUpError = "That email is already registered.";
                return;
            }

            if (response.StatusCode == HttpStatusCode.BadRequest)
            {
                _signUpError = "Please check your email and password and try again.";
                return;
            }

            response.EnsureSuccessStatusCode();
            await response.Content.ReadFromJsonAsync<AuthRegisterResponse>();

            var login = await Http.PostAsJsonAsync("auth/login", new { email = _signUpEmail, password = _signUpPassword });
            login.EnsureSuccessStatusCode();

            var payload = await login.Content.ReadFromJsonAsync<AuthLoginResponse>();
            if (payload is null || string.IsNullOrEmpty(payload.AccessToken))
            {
                _signUpSuccess = "Account created. You can sign in now.";
                _tab = Tab.SignIn;
                _signInEmail = _signUpEmail.Trim();
                _signInPassword = "";
                return;
            }

            CompleteSignIn(_signUpEmail, payload);
        }
        catch (Exception ex)
        {
            _signUpError = $"Could not create account: {ex.Message}";
        }
        finally
        {
            _busy = false;
        }
    }

    private void CompleteSignIn(string email, AuthLoginResponse payload)
    {
        Session.Email = email.Trim();
        Session.AccessToken = payload.AccessToken;
        Session.RefreshToken = payload.RefreshToken;
        Session.NotifyChanged();

        var next = Session.ReturnAfterSignIn;
        Session.ReturnAfterSignIn = null;
        if (!string.IsNullOrEmpty(next))
        {
            try
            {
                var parsed = new Uri(next, UriKind.Absolute);
                var baseAuthority = new Uri(Nav.BaseUri).GetLeftPart(UriPartial.Authority).TrimEnd('/');
                var candAuthority = parsed.GetLeftPart(UriPartial.Authority).TrimEnd('/');
                if (string.Equals(baseAuthority, candAuthority, StringComparison.OrdinalIgnoreCase))
                {
                    Nav.NavigateTo(parsed.PathAndQuery + parsed.Fragment);
                    return;
                }
            }
            catch (UriFormatException)
            {
                // fall through to default
            }
        }

        Nav.NavigateTo("/now-playing");
    }
}
