@page "/checkout"
@using BlazorApp1.Services
@inject NavigationManager Nav
@inject UserSession Session

<PageTitle>Checkout</PageTitle>

<div class="container mt-4 pb-5">
    <h1 class="mb-3">Checkout</h1>

    @if (!Session.IsSignedIn)
    {
        <p class="text-muted mb-4">Sign in to continue with your booking.</p>
        <a class="btn btn-primary me-2" href="/account">Sign in</a>
        <button type="button" class="btn btn-secondary" @onclick="GoHome">Back to Home</button>
    }
    else
    {
        <p class="text-muted mb-4">This checkout flow is under construction. Thanks for your patience.</p>
        <button type="button" class="btn btn-secondary" @onclick="GoHome">Back to Home</button>
    }
</div>

@code {
    private void GoHome()
    {
        Nav.NavigateTo("/");
    }
}
