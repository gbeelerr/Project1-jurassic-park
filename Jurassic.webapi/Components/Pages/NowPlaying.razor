@page "/now-playing"
@using BlazorApp1.Models
@using System.Net.Http.Json
@using System.Globalization
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>Now Playing</PageTitle>

<div class="container mt-4 pb-5">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <h1 class="display-5 fw-bold text-primary">Now Playing</h1>
        <button class="btn btn-outline-secondary" @onclick="GoHome">
            Back Home
        </button>
    </div>

    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-4">
        <p class="lead text-muted mb-0">Select a date, then pick a movie/showtime to start booking.</p>
        <div class="d-flex align-items-center gap-2">
            <label class="small text-muted fw-semibold mb-0" for="nowPlayingDate">Show date</label>
            <input id="nowPlayingDate"
                   type="date"
                   class="form-control"
                   style="max-width: 180px;"
                   value="@_selectedDateIso"
                   @onchange="OnDateChanged" />
        </div>
    </div>

    @if (_isError)
    {
        <div class="alert alert-danger shadow-sm py-4" role="alert">
            <h4 class="alert-heading fw-bold">Connection Error</h4>
            <p class="mb-0">Movies currently not available. Our systems might be experiencing some issues. Please try again later.</p>
        </div>
    }
    else if (movies == null)
    {
        <div class="text-center my-5 py-5">
            <div class="spinner-border text-primary mb-3" style="width: 3rem; height: 3rem;" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="text-muted">Fetching the latest blockbusters...</p>
        </div>
    }
    else if (movies.Count == 0)
    {
        <div class="alert alert-info shadow-sm py-4 text-center" role="alert">
            <h4 class="alert-heading fw-bold">No Movies Currently Showing</h4>
            <p class="mb-0">Please check back later for the next scheduled features.</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var movie in movies)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm transition-hover">
                        @if (!string.IsNullOrEmpty(movie.PosterUrl))
                        {
                            <img src="@movie.PosterUrl" class="card-img-top" alt="@movie.Title Poster" style="object-fit: cover; height: 350px;">
                        }
                        else
                        {
                            <div class="card-img-top bg-dark d-flex flex-column align-items-center justify-content-center text-white p-4" style="height: 350px;">
                                <div class="mb-2 text-secondary h4">Now Showing</div>
                                <h5 class="fw-bold text-center">@movie.Title</h5>
                                <span class="badge bg-secondary mt-2">Poster Coming Soon</span>
                            </div>
                        }

                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <h5 class="card-title fw-bold mb-0">@movie.Title</h5>
                                <span class="badge bg-info text-dark">@movie.Rating</span>
                            </div>

                            <div class="d-flex flex-wrap gap-2 mb-3 text-muted small">
                                <span class="d-inline-flex align-items-center">
                                    Runtime: @movie.DurationMins mins
                                </span>
                                <span class="d-inline-flex align-items-center">
                                    Screen: @movie.ScreenName (@movie.ScreenType)
                                </span>
                            </div>

                            <button class="btn btn-outline-info btn-sm w-100" @onclick="() => ShowDescription(movie)">
                                Movie Info
                            </button>
                        </div>

                        <div class="card-footer bg-white border-top-0 pt-0 pb-3 px-3">
                            <div class="small text-uppercase fw-bold text-muted mb-2">Showtimes</div>
                            @if (movie.Showtimes != null && movie.Showtimes.Any())
                            {
                                @foreach (var showtimeGroup in GetShowtimeGroups(movie.Showtimes))
                                {
                                    <div class="showtime-day mb-3">
                                        <div class="small fw-semibold text-dark mb-2">@FormatShowDate(showtimeGroup.Key)</div>
                                        <div class="showtime-grid">
                                            @foreach (var showtime in showtimeGroup)
                                            {
                                                <button class="btn btn-success shadow-sm fw-bold showtime-button" @onclick="() => GoToSeatSelector(movie.MovieId, showtime.ShowtimeId)">
                                                    <span>@FormatShowTime(showtime.StartsAt)</span>
                                                    <span class="small">@FormatUsd(showtime.BasePrice)</span>
                                                </button>
                                            }
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="text-muted small">No showtimes available for this screen.</div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (_selectedMovie != null)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.6); backdrop-filter: blur(4px);" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-lg border-0">
                <div class="modal-header bg-primary text-white border-0">
                    <h5 class="modal-title fw-bold">@_selectedMovie.Title</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseDescription"></button>
                </div>
                <div class="modal-body p-4">
                    @if (!string.IsNullOrWhiteSpace(_selectedMovie.PosterUrl))
                    {
                        <img src="@_selectedMovie.PosterUrl"
                             class="w-100 rounded mb-3"
                             alt="@_selectedMovie.Title Poster"
                             style="max-height: 320px; object-fit: cover;" />
                    }
                    <div class="d-flex mb-3 gap-2">
                        <span class="badge bg-secondary">Rating: @_selectedMovie.Rating</span>
                        <span class="badge bg-secondary">Duration: @_selectedMovie.DurationMins mins</span>
                    </div>
                    <h6 class="fw-bold text-uppercase small text-muted mb-2">Synopsis</h6>
                    <p class="text-secondary mb-4" style="line-height: 1.6;">
                        @(!string.IsNullOrWhiteSpace(_selectedMovie.Description)
                            ? _selectedMovie.Description
                            : "Synopsis coming soon.")
                    </p>

                    <h6 class="fw-bold text-uppercase small text-muted mb-2">Screening Details</h6>
                    <p class="mb-3 text-dark">
                        Screen: <strong>@_selectedMovie.ScreenName</strong> (@_selectedMovie.ScreenType)
                    </p>

                    <h6 class="fw-bold text-uppercase small text-muted mb-2">Available Showtimes</h6>
                    <div class="mb-4">
                        @if (_selectedMovie.Showtimes != null && _selectedMovie.Showtimes.Any())
                        {
                            @foreach (var showtimeGroup in GetShowtimeGroups(_selectedMovie.Showtimes))
                            {
                                <div class="showtime-day mb-3">
                                    <div class="small fw-semibold text-dark mb-2">@FormatShowDate(showtimeGroup.Key)</div>
                                    <div class="showtime-grid">
                                        @foreach (var showtime in showtimeGroup)
                                        {
                                            <button type="button" class="btn btn-outline-success showtime-button" @onclick="() => BookSelectedShowtime(_selectedMovie.MovieId, showtime.ShowtimeId, showtime.StartsAt, showtime.BasePrice)">
                                                <span>@FormatShowTime(showtime.StartsAt)</span>
                                                <span class="small">@FormatUsd(showtime.BasePrice)</span>
                                            </button>
                                        }
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <span class="text-muted small italic">No showtimes available for this screen.</span>
                        }
                    </div>
                </div>
                <div class="modal-footer border-top-0 p-3">
                    <button type="button" class="btn btn-secondary px-4" @onclick="CloseDescription">Close</button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .transition-hover {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .transition-hover:hover {
        transform: translateY(-8px);
        box-shadow: 0 1rem 3rem rgba(0,0,0,.175)!important;
    }

    .showtime-grid {
        display: grid;
        gap: 0.75rem;
        grid-template-columns: repeat(auto-fit, minmax(110px, 1fr));
    }

    .showtime-button {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 68px;
    }
</style>

@code {
    private List<Movie>? movies;
    private bool _isError;
    private Movie? _selectedMovie;
    private string _selectedDateIso = DateTime.UtcNow.ToString("yyyy-MM-dd");
    private static readonly CultureInfo UsCulture = CultureInfo.GetCultureInfo("en-US");

    protected override async Task OnInitializedAsync()
    {
        await FetchMoviesAsync();
    }

    private async Task OnDateChanged(ChangeEventArgs e)
    {
        _selectedDateIso = e.Value?.ToString() ?? DateTime.UtcNow.ToString("yyyy-MM-dd");
        await FetchMoviesAsync();
    }

    private async Task FetchMoviesAsync()
    {
        _isError = false;
        movies = null;

        try
        {
            var url = $"movies/now-playing?date={Uri.EscapeDataString(_selectedDateIso)}";
            movies = await Http.GetFromJsonAsync<List<Movie>>(url);
        }
        catch (Exception ex)
        {
            _isError = true;
            Console.WriteLine($"Error fetching movies: {ex.Message}");
        }
    }

    private void ShowDescription(Movie movie)
    {
        _selectedMovie = movie;
    }

    private void CloseDescription()
    {
        _selectedMovie = null;
    }

    private static IEnumerable<IGrouping<DateOnly, ShowtimeDetail>> GetShowtimeGroups(IEnumerable<ShowtimeDetail> showtimes)
    {
        return showtimes
            .OrderBy(showtime => showtime.StartsAt)
            .GroupBy(showtime => DateOnly.FromDateTime(showtime.StartsAt));
    }

    private static string FormatShowDate(DateOnly date)
    {
        return date.ToString("ddd, M/d");
    }

    private static string FormatShowTime(DateTime startsAt)
    {
        return startsAt.ToString("h:mm tt");
    }

    private static string FormatUsd(decimal amount) => string.Format(UsCulture, "{0:C}", amount);

    private void BookSelectedShowtime(Guid movieId, Guid showtimeId, DateTime startsAt, decimal basePrice)
    {
        CloseDescription();
        GoToSeatSelector(movieId, showtimeId, startsAt, basePrice);
    }

    private void GoToSeatSelector(Guid movieId, Guid? showtimeId = null, DateTime? startsAt = null, decimal? basePrice = null)
    {
        // Pass enough info for Seat Selector to display a real selection summary
        // (even before a dedicated showtime-details endpoint exists).
        var query = new List<string> { $"movieId={movieId}" };

        if (showtimeId.HasValue)
        {
            query.Add($"showtimeId={showtimeId.Value}");
        }

        if (startsAt.HasValue)
        {
            query.Add($"startsAt={Uri.EscapeDataString(startsAt.Value.ToUniversalTime().ToString("o"))}");
        }

        if (basePrice.HasValue)
        {
            query.Add($"basePrice={Uri.EscapeDataString(basePrice.Value.ToString(CultureInfo.InvariantCulture))}");
        }

        var url = "/seat-selector" + (query.Count > 0 ? "?" + string.Join("&", query) : "");

        Nav.NavigateTo(url);
    }

    private void GoHome()
    {
        Nav.NavigateTo("/");
    }
}
