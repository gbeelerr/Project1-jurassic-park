@page "/"
@using BlazorApp1.Models
@using System.Net.Http.Json
@using System.Linq
@implements IAsyncDisposable
@inject HttpClient Http

<PageTitle>Home</PageTitle>

<div class="container py-5 home-page d-flex flex-column page-shell">
    <div class="home-hero text-center mb-4">
        <h1 class="display-4 fw-bold mb-2">Jurassic Park Cinema</h1>
        <p class="lead text-muted mb-0">Reserve your favorite seats for the latest showtimes.</p>
    </div>

    @if (_isError)
    {
        <div class="alert alert-danger text-center" role="alert">
            Unable to load movies right now. Please try again shortly.
        </div>
    }
    else if (movies == null)
    {
        <div class="text-center my-5 py-5">
            <div class="spinner-border text-primary mb-3" style="width: 3rem; height: 3rem;" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="text-muted mb-0">Loading movies...</p>
        </div>
    }
    else if (movieSlides.Count == 0)
    {
        <div class="alert alert-info text-center" role="alert">
            No movie posters found.
        </div>
    }
    else
    {
        <div id="moviePosterCarouselDesktop"
             class="carousel slide poster-carousel-shell d-none d-md-block @(_desktopSlideForward ? "slide-forward" : "slide-back")"
             @onmouseenter="OnDesktopMouseEnter"
             @onmouseleave="OnDesktopMouseLeave">
            <div class="carousel-indicators">
                @for (var i = 0; i < movieSlides.Count; i++)
                {
                    <button type="button"
                            class="@(i == activeSlideIndex ? "active" : null)"
                            aria-current="@(i == activeSlideIndex ? "true" : null)"
                            aria-label="@($"Slide {i + 1}")"
                            @onclick="() => GoToSlide(i)"></button>
                }
            </div>

            <div class="carousel-inner">
                @for (var i = 0; i < movieSlides.Count; i++)
                {
                    <div class="carousel-item @(i == activeSlideIndex ? "active" : null)">
                        <div class="row g-4 justify-content-center px-5">
                            @foreach (var movie in movieSlides[i])
                            {
                                <div class="col-12 col-sm-6 col-lg-4 d-flex">
                                    <div class="poster-frame w-100 d-flex flex-column align-items-center">
                                        <img src="@movie.PosterUrl"
                                             class="d-block poster-image"
                                             alt="@($"{movie.Title} poster")" />
                                        <h5 class="mt-3 mb-0 text-center fw-bold">@movie.Title</h5>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

            <button class="carousel-control-prev" type="button" @onclick="PreviousSlide">
                <span class="carousel-control-prev-icon carousel-nav-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Previous</span>
            </button>
            <button class="carousel-control-next" type="button" @onclick="NextSlide">
                <span class="carousel-control-next-icon carousel-nav-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Next</span>
            </button>
        </div>

        <div id="moviePosterCarouselMobile"
             class="carousel slide poster-carousel-shell-mobile d-md-none @(_mobileSlideForward ? "slide-forward" : "slide-back")"
             @onmouseenter="OnMobileMouseEnter"
             @onmouseleave="OnMobileMouseLeave">
            <div class="carousel-indicators">
                @for (var i = 0; i < mobileMovies.Count; i++)
                {
                    <button type="button"
                            class="@(i == activeMobileSlideIndex ? "active" : null)"
                            aria-current="@(i == activeMobileSlideIndex ? "true" : null)"
                            aria-label="@($"Slide {i + 1}")"
                            @onclick="() => GoToMobileSlide(i)"></button>
                }
            </div>

            <div class="carousel-inner">
                @for (var i = 0; i < mobileMovies.Count; i++)
                {
                    var movie = mobileMovies[i];
                    <div class="carousel-item @(i == activeMobileSlideIndex ? "active" : null)">
                        <div class="row g-4 justify-content-center px-2">
                            <div class="col-12 d-flex">
                                <div class="poster-frame w-100 d-flex flex-column align-items-center">
                                    <img src="@movie.PosterUrl"
                                         class="d-block poster-image"
                                         alt="@($"{movie.Title} poster")" />
                                    <h5 class="mt-3 mb-0 text-center fw-bold">@movie.Title</h5>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <button class="carousel-control-prev" type="button" @onclick="PreviousMobileSlide">
                <span class="carousel-control-prev-icon carousel-nav-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Previous</span>
            </button>
            <button class="carousel-control-next" type="button" @onclick="NextMobileSlide">
                <span class="carousel-control-next-icon carousel-nav-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Next</span>
            </button>
        </div>
    }
    <div class="d-flex justify-content-center mt-4 mb-2">
        <a class="btn btn-primary btn-lg home-cta" href="/now-playing">
            Get Tickets
        </a>
    </div>
</div>

<style>
    .home-page {
        min-height: calc(100vh - 3.5rem);
        padding-bottom: 2rem;
    }

    .home-hero {
        color: #fff;
        padding-top: 1rem;
    }

    .home-hero h1 {
        color: #fff;
        letter-spacing: 0;
    }

    .home-hero .lead {
        color: rgba(255, 255, 255, 0.72) !important;
    }

    .home-page > #moviePosterCarouselDesktop,
    .home-page > #moviePosterCarouselMobile {
        margin-top: auto;
        margin-bottom: auto;
    }

    .poster-image {
        width: min(100%, 320px);
        max-width: 260px;
        height: 390px;
        object-fit: cover;
        border-radius: 0.65rem;
        box-shadow: 0 24px 55px rgba(0, 0, 0, 0.32);
        border: 1px solid rgba(255, 255, 255, 0.18);
    }

    .poster-frame h5 {
        color: #fff;
        text-shadow: 0 2px 14px rgba(0, 0, 0, 0.35);
    }

    #moviePosterCarouselDesktop .carousel-indicators button,
    #moviePosterCarouselMobile .carousel-indicators button {
        background-color: rgba(255, 255, 255, 0.75);
        width: 10px;
        height: 10px;
        border-radius: 50%;
        border: 0;
        opacity: 0.45;
    }

    #moviePosterCarouselDesktop .carousel-indicators .active,
    #moviePosterCarouselMobile .carousel-indicators .active {
        opacity: 1;
        background-color: #d6a84f;
    }

    .carousel-nav-icon {
        background-color: rgba(10, 15, 24, 0.82);
        border-radius: 999px;
        padding: 1.1rem;
        background-size: 55% 55%;
        border: 1px solid rgba(255, 255, 255, 0.16);
    }

    .poster-carousel-shell {
        padding-inline: 2.75rem;
    }

    .poster-carousel-shell-mobile {
        padding-inline: 0.25rem;
    }

    .home-cta {
        min-width: 220px;
        padding: 0.95rem 2.4rem;
        box-shadow: 0 18px 35px rgba(122, 27, 21, 0.28);
    }

    #moviePosterCarouselDesktop.slide-forward .carousel-item.active,
    #moviePosterCarouselMobile.slide-forward .carousel-item.active {
        animation: slideInFromRight 420ms ease-out;
    }

    #moviePosterCarouselDesktop.slide-back .carousel-item.active,
    #moviePosterCarouselMobile.slide-back .carousel-item.active {
        animation: slideInFromLeft 420ms ease-out;
    }

    @@keyframes slideInFromRight {
        from {
            opacity: 0.6;
            transform: translateX(24px);
        }
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    @@keyframes slideInFromLeft {
        from {
            opacity: 0.6;
            transform: translateX(-24px);
        }
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }
</style>

@code {
    private const int AutoSlideIntervalSeconds = 10;
    private List<Movie>? movies;
    private List<Movie> mobileMovies = new();
    private List<List<Movie>> movieSlides = new();
    private int activeSlideIndex;
    private int activeMobileSlideIndex;
    private bool _isError;
    private bool _desktopSlideForward = true;
    private bool _mobileSlideForward = true;
    private bool _desktopHovered;
    private bool _mobileHovered;
    private DateTime _lastUserInteractionUtc = DateTime.UtcNow;
    private DateTime _lastAutoAdvanceUtc = DateTime.UtcNow;
    private CancellationTokenSource? _autoSlideCts;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            movies = await Http.GetFromJsonAsync<List<Movie>>("movies/posters") ?? new List<Movie>();
            var linkedMovies = movies
                .Where(movie => !string.IsNullOrWhiteSpace(movie.PosterUrl))
                .ToList();

            mobileMovies = linkedMovies;
            movieSlides = BuildDesktopSlides(linkedMovies);
        }
        catch (Exception ex)
        {
            _isError = true;
            Console.WriteLine($"Error fetching movie posters: {ex.Message}");
        }
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_isError)
        {
            StartAutoSlideLoop();
        }

        return Task.CompletedTask;
    }

    private void PreviousSlide()
    {
        if (movieSlides.Count == 0)
        {
            return;
        }

        _desktopSlideForward = false;
        RegisterUserInteraction();
        activeSlideIndex = (activeSlideIndex - 1 + movieSlides.Count) % movieSlides.Count;
    }

    private void NextSlide()
    {
        if (movieSlides.Count == 0)
        {
            return;
        }

        _desktopSlideForward = true;
        RegisterUserInteraction();
        activeSlideIndex = (activeSlideIndex + 1) % movieSlides.Count;
    }

    private void GoToSlide(int index)
    {
        if (index < 0 || index >= movieSlides.Count)
        {
            return;
        }

        _desktopSlideForward = index >= activeSlideIndex;
        RegisterUserInteraction();
        activeSlideIndex = index;
    }

    private void PreviousMobileSlide()
    {
        if (mobileMovies.Count == 0)
        {
            return;
        }

        _mobileSlideForward = false;
        RegisterUserInteraction();
        activeMobileSlideIndex = (activeMobileSlideIndex - 1 + mobileMovies.Count) % mobileMovies.Count;
    }

    private void NextMobileSlide()
    {
        if (mobileMovies.Count == 0)
        {
            return;
        }

        _mobileSlideForward = true;
        RegisterUserInteraction();
        activeMobileSlideIndex = (activeMobileSlideIndex + 1) % mobileMovies.Count;
    }

    private void GoToMobileSlide(int index)
    {
        if (index < 0 || index >= mobileMovies.Count)
        {
            return;
        }

        _mobileSlideForward = index >= activeMobileSlideIndex;
        RegisterUserInteraction();
        activeMobileSlideIndex = index;
    }

    private static List<List<Movie>> BuildDesktopSlides(List<Movie> source)
    {
        if (source.Count == 0)
        {
            return new List<List<Movie>>();
        }

        var windowSize = Math.Min(3, source.Count);
        var windows = new List<List<Movie>>(source.Count);

        for (var i = 0; i < source.Count; i++)
        {
            var window = new List<Movie>(windowSize);
            for (var offset = 0; offset < windowSize; offset++)
            {
                window.Add(source[(i + offset) % source.Count]);
            }

            windows.Add(window);
        }

        return windows;
    }

    private void StartAutoSlideLoop()
    {
        _autoSlideCts = new CancellationTokenSource();
        _ = Task.Run(() => AutoSlideLoopAsync(_autoSlideCts.Token));
    }

    private async Task AutoSlideLoopAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(1));

        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                if (!ShouldAutoAdvance())
                {
                    continue;
                }

                await InvokeAsync(() =>
                {
                    AdvanceDesktopAuto();
                    AdvanceMobileAuto();
                    _lastAutoAdvanceUtc = DateTime.UtcNow;
                    StateHasChanged();
                });
            }
        }
        catch (OperationCanceledException)
        {
            // Component disposed or loop cancelled.
        }
    }

    private bool ShouldAutoAdvance()
    {
        if (_desktopHovered || _mobileHovered)
        {
            return false;
        }

        var now = DateTime.UtcNow;
        return (now - _lastUserInteractionUtc).TotalSeconds >= AutoSlideIntervalSeconds
            && (now - _lastAutoAdvanceUtc).TotalSeconds >= AutoSlideIntervalSeconds;
    }

    private void AdvanceDesktopAuto()
    {
        if (movieSlides.Count == 0)
        {
            return;
        }

        _desktopSlideForward = true;
        activeSlideIndex = (activeSlideIndex + 1) % movieSlides.Count;
    }

    private void AdvanceMobileAuto()
    {
        if (mobileMovies.Count == 0)
        {
            return;
        }

        _mobileSlideForward = true;
        activeMobileSlideIndex = (activeMobileSlideIndex + 1) % mobileMovies.Count;
    }

    private void RegisterUserInteraction()
    {
        _lastUserInteractionUtc = DateTime.UtcNow;
    }

    private void OnDesktopMouseEnter()
    {
        _desktopHovered = true;
    }

    private void OnDesktopMouseLeave()
    {
        _desktopHovered = false;
        RegisterUserInteraction();
    }

    private void OnMobileMouseEnter()
    {
        _mobileHovered = true;
    }

    private void OnMobileMouseLeave()
    {
        _mobileHovered = false;
        RegisterUserInteraction();
    }

    public ValueTask DisposeAsync()
    {
        _autoSlideCts?.Cancel();
        _autoSlideCts?.Dispose();
        return ValueTask.CompletedTask;
    }
}
